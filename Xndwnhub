            menuFrame.Visible = not menuFrame.Visible
            lastClick = tick()
        end
    end)
    
    -- ========================================
    -- ATUALIZAR INFO
    -- ========================================
    
    spawn(function()
        while screenGui.Parent do
            playersLabel.Text = "👥 Players no servidor: " .. #Players:GetPlayers()
