    XANDOWN HUB - PREHISTORIC ISLAND
    HIT SPEED: 20 a 200 hits por segundo
    TWEEN SPEED: 0.1 a 1 segundo
    BOAT SPEED: 50 a 300
    SEARCH SPEED: 0.5 a 5 segundos
--]]

local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local Workspace = game:GetService("Workspace")
