-- ============================================
-- CONFIGURAÇÕES (AJUSTÁVEIS PELA GUI)
-- ============================================

local Settings = {
    -- Velocidades (min e max)
    HitSpeed = 50,           -- 20 a 200 hits/segundo
    TweenSpeed = 0.3,        -- 0.1 a 1 segundo
    BoatSpeed = 120,         -- 50 a 300
    SearchSpeed = 2,         -- 0.5 a 5 segundos
    
    -- Status
    Ativo = false,
    Modo = "PROCURAR",       -- PROCURAR, RACHADURAS, COMBATE
    
    -- Barco
    BarcoSelecionado = "Milagre",
    
    -- Posições
    SafeZone = nil,
}

-- ============================================
-- UTILITÁRIOS
-- ============================================

local function GetRoot()
    local char = Player.Character
    if not char then return nil end
    return char:FindFirstChild("HumanoidRootPart")
end

local function Teleportar(posicao)
    local root = GetRoot()
    if root then
        root.CFrame = CFrame.new(posicao)
    end
end

local function MoverSuave(posicao)
    local root = GetRoot()
    if not root then return end
    local tween = TweenService:Create(root, TweenInfo.new(Settings.TweenSpeed, Enum.EasingStyle.Linear), {
        CFrame = CFrame.new(posicao)
    })
    tween:Play()
    return tween
end

-- ============================================
-- DETECÇÃO DA ILHA
-- ============================================

local function EncontrarIlha()
    local island = Workspace:FindFirstChild("PrehistoricIsland")
    if island then
        local relic = island:FindFirstChild("Relic") or island:FindFirstChild("Fossil")
        if relic then
            Settings.SafeZone = relic.Position + Vector3.new(0, -10, 25)
            return island, relic.Position
        end
        local pos = island.PrimaryPart and island.PrimaryPart.Position
        if pos then
            Settings.SafeZone = pos + Vector3.new(0, -10, 25)
            return island, pos
        end
    end
    return nil, nil
end

-- ============================================
-- DETECÇÃO DE RACHADURAS
-- ============================================

local function EncontrarRachaduras()
    local rachaduras = {}
    local myRoot = GetRoot()
    
    for _, obj in pairs(Workspace:GetDescendants()) do
        if obj:IsA("BasePart") then
            local nome = obj.Name:lower()
            if nome:find("crack") or nome:find("rachadura") or nome:find("hotspot") or nome:find("pressure") then
                table.insert(rachaduras, {
                    Part = obj,
                    Position = obj.Position,
                    Distance = myRoot and (myRoot.Position - obj.Position).Magnitude or math.huge
                })
            end
        end
    end
    
    table.sort(rachaduras, function(a,b) return a.Distance < b.Distance end)
    return rachaduras
end

-- ============================================
-- DETECÇÃO DE GOLEMS
-- ============================================

local function EncontrarGolems()
    local golems = {}
    local myRoot = GetRoot()
    
    for _, obj in pairs(Workspace:GetDescendants()) do
        if obj:IsA("Model") and obj:FindFirstChild("Humanoid") then
            local nome = obj.Name:lower()
            if (nome:find("lava") and nome:find("golem")) or nome:find("magma") then
                local humanoid = obj.Humanoid
                if humanoid and humanoid.Health > 0 then
                    local root = obj:FindFirstChild("HumanoidRootPart")
                    if root then
                        table.insert(golems, {
                            Model = obj,
                            Root = root,
                            Humanoid = humanoid,
                            Distance = myRoot and (myRoot.Position - root.Position).Magnitude or math.huge
                        })
                    end
                end
            end
        end
    end
    
    table.sort(golems, function(a,b) return a.Distance < b.Distance end)
    return golems
end

-- ============================================
-- ATAQUE AUTOMÁTICO (PASSIVO COM HIT SPEED)
-- ============================================

local AtaqueAtivo = false
local LoopAtaque = nil
local UltimoTempoAtaque = 0

local function Atacar()
    -- Verifica se está segurando uma ferramenta
    local char = Player.Character
    if not char then return end
    
    local temFerramenta = false
    for _, tool in pairs(char:GetChildren()) do
        if tool:IsA("Tool") then
            temFerramenta = true
            break
        end
    end
    
    if not temFerramenta then return end
    
    -- Executa o clique
    VirtualInputManager:SendMouseButtonEvent(Enum.UserInputType.MouseButton1, 0, 0, true)
    task.wait(0.02)
    VirtualInputManager:SendMouseButtonEvent(Enum.UserInputType.MouseButton1, 0, 0, false)
end

local function IniciarAtaquePassivo()
    if AtaqueAtivo then return end
    AtaqueAtivo = true
    
    local hitDelay = 1 / math.clamp(Settings.HitSpeed, 20, 200)
    
    LoopAtaque = RunService.Heartbeat:Connect(function()
        if not Settings.Ativo then return end
        
        local agora = tick()
        if agora - UltimoTempoAtaque >= hitDelay then
            UltimoTempoAtaque = agora
            Atacar()
        end
    end)
end

local function PararAtaquePassivo()
    AtaqueAtivo = false
    if LoopAtaque then
        LoopAtaque:Disconnect()
        LoopAtaque = nil
    end
end

-- ============================================
-- USAR SKILLS (APENAS RACHADURAS)
-- ============================================

local function UsarSkill(tecla)
    VirtualInputManager:SendKeyEvent(true, tecla, false, game)
    task.wait(0.05)
    VirtualInputManager:SendKeyEvent(false, tecla, false, game)
end

local function ExecutarComboSkills()
    local skills = {"V", "X", "C", "Z", "F"}
    for _, skill in pairs(skills) do
        UsarSkill(skill)
        task.wait(0.08)
    end
end

-- ============================================
-- FECHAR RACHADURAS (PRIORIDADE MÁXIMA)
-- ============================================

local function FecharRachaduras()
    local rachaduras = EncontrarRachaduras()
    if #rachaduras == 0 then return false end
    
    Settings.Modo = "RACHADURAS"
    
    for _, crack in pairs(rachaduras) do
        if crack.Distance > 25 then
            MoverSuave(crack.Position)
            task.wait(Settings.TweenSpeed + 0.2)
        end
        ExecutarComboSkills()
        task.wait(0.2)
    end
    
    return true
end

-- ============================================
-- CONTROLAR GOLEMS (BRING PARA ZONA SEGURA)
-- ============================================

local function ControlarGolems()
    local golems = EncontrarGolems()
    if #golems == 0 then return false end
    
    Settings.Modo = "COMBATE"
    
    for _, golem in pairs(golems) do
        if golem.Distance < 50 then
            -- Teleporta o Golem para a SafeZone (funciona em NPCs)
            pcall(function()
                if Settings.SafeZone then
                    golem.Root.CFrame = CFrame.new(Settings.SafeZone)
                end
            end)
            task.wait(0.05)
        end
    end
    
    return true
end

-- ============================================
-- COMPRAR BARCO
-- ============================================

local function ComprarBarco(nome)
    local remotes = {
        ReplicatedStorage:FindFirstChild("Remotes", true),
        ReplicatedStorage:FindFirstChild("BoatRemote", true)
    }
    
    for _, remote in pairs(remotes) do
        if remote then
            pcall(function()
                remote:FireServer("Buy", nome)
            end)
        end
    end
    print("🚤 Barco solicitado: " .. nome)
end

-- ============================================
-- NAVEGAÇÃO (PROCURAR ILHA)
-- ============================================

local Navegando = false
local LoopNavegacao = nil
local Angulo = 0

local function MoverProcura()
    local root = GetRoot()
    if not root then return end
    
    Angulo = Angulo + (0.03 * (2 / Settings.SearchSpeed))
    local raio = math.min(80, Settings.BoatSpeed / 2)
    local dx = math.cos(Angulo) * raio
    local dz = math.sin(Angulo) * raio
    
    local destino = root.Position + Vector3.new(dx, 0, dz)
    
    local ray = Workspace:Raycast(destino + Vector3.new(0, 50, 0), Vector3.new(0, -100, 0))
    if ray then
        destino = Vector3.new(destino.X, ray.Position.Y + 3, destino.Z)
    end
    
    MoverSuave(destino)
end

local function IniciarBusca()
    if Navegando then return end
    Navegando = true
    Settings.Ativo = true
    Settings.Modo = "PROCURAR"
    
    IniciarAtaquePassivo()
    ComprarBarco(Settings.BarcoSelecionado)
    
    print("========================================")
    print("🦖 XANDOWN - PREHISTORIC ISLAND")
    print("⚡ Hit Speed: " .. Settings.HitSpeed .. "/s")
    print("🌀 Tween Speed: " .. Settings.TweenSpeed .. "s")
    print("🚤 Boat Speed: " .. Settings.BoatSpeed)
    print("🔍 Search Speed: " .. Settings.SearchSpeed .. "s")
    print("========================================")
    
    LoopNavegacao = RunService.Heartbeat:Connect(function()
        if not Settings.Ativo then
            if LoopNavegacao then LoopNavegacao:Disconnect() end
            Navegando = false
            return
        end
        
        local island, pos = EncontrarIlha()
        if island and pos then
            print("🏝️ ILHA ENCONTRADA! INDO PARA RELÍQUIA...")
            MoverSuave(pos)
            task.wait(Settings.TweenSpeed + 1)
            
            -- Loop do evento (prioridades)
            spawn(function()
                while Settings.Ativo do
                    -- PRIORIDADE 1: Rachaduras (usa skills)
                    if FecharRachaduras() then
                        task.wait(0.5)
                        goto continuar
                    end
                    
                    -- PRIORIDADE 2: Golems (aplica bring)
                    ControlarGolems()
                    
                    ::continuar::
                    task.wait(0.2)
                end
            end)
            return
        end
        
        MoverProcura()
        task.wait(Settings.SearchSpeed)
    end)
end

local function PararBusca()
    Settings.Ativo = false
    Navegando = false
    PararAtaquePassivo()
    if LoopNavegacao then
        LoopNavegacao:Disconnect()
        LoopNavegacao = nil
    end
    print("⏹️ BUSCA PARADA")
end

