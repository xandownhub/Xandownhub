        if isDraggingBtn and (input.UserInputType == Enum.UserInputType.Touch or input.UserInputType == Enum.UserInputType.MouseMovement) then
            local delta = input.Position - btnDragStart
            local newX = floatingBtn.Position.X.Offset + delta.X
            local newY = floatingBtn.Position.Y.Offset + delta.Y
            newX = math.clamp(newX, 0, 700)
            newY = math.clamp(newY, 50, 550)
            floatingBtn.Position = UDim2.new(0, newX, 0, newY)
            btnDragStart = input.Position
        end
    end)
    
    floatingBtn.InputEnded:Connect(function()
        isDraggingBtn = false
    end)
    
