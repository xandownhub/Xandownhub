            Settings.BoatSpeed = value
        end
        
        if draggingSearch and (input.UserInputType == Enum.UserInputType.Touch or input.UserInputType == Enum.UserInputType.MouseMovement) then
            local pos = math.clamp((input.Position.X - searchSliderBg.AbsolutePosition.X) / searchSliderBg.AbsoluteSize.X, 0, 1)
            local value = 0.5 + (pos * 4.5)
            searchSliderFill.Size = UDim2.new(pos, 0, 1, 0)
            searchKnob.Position = UDim2.new(pos, -6, 0.5, -6)
            searchLabel.Text = "🔍 Search Speed: " .. string.format("%.1f", value) .. "s"
            Settings.SearchSpeed = value
