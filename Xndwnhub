    boatKnob.InputEnded:Connect(function() draggingBoat = false end)
    
    -- Search Speed (0.5-5)
    searchSliderBg.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.Touch or input.UserInputType == Enum.UserInputType.MouseButton1 then
            local pos = math.clamp((input.Position.X - searchSliderBg.AbsolutePosition.X) / searchSliderBg.AbsoluteSize.X, 0, 1)
