    searchKnob.InputEnded:Connect(function() draggingSearch = false end)
    
    -- Movimento dos sliders
    UserInputService.InputChanged:Connect(function(input)
        if draggingHit and (input.UserInputType == Enum.UserInputType.Touch or input.UserInputType == Enum.UserInputType.MouseMovement) then
            local pos = math.clamp((input.Position.X - hitSliderBg.AbsolutePosition.X) / hitSliderBg.AbsoluteSize.X, 0, 1)
            local value = math.floor(20 + (pos * 180))
            hitSliderFill.Size = UDim2.new(pos, 0, 1, 0)
            hitKnob.Position = UDim2.new(pos, -6, 0.5, -6)
            hitLabel.Text = "⚔️ Hit Speed: " .. value .. "/s"
