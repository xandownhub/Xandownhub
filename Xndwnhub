    hitSliderBg.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.Touch or input.UserInputType == Enum.UserInputType.MouseButton1 then
            local pos = math.clamp((input.Position.X - hitSliderBg.AbsolutePosition.X) / hitSliderBg.AbsoluteSize.X, 0, 1)
            local value = math.floor(20 + (pos * 180))
            hitSliderFill.Size = UDim2.new(pos, 0, 1, 0)
            hitKnob.Position = UDim2.new(pos, -6, 0.5, -6)
            hitLabel.Text = "⚔️ Hit Speed: " .. value .. "/s"
            Settings.HitSpeed = value
            draggingHit = true
        end
    end)
    
    hitKnob.InputBegan:Connect(function() draggingHit = true end)
    hitKnob.InputEnded:Connect(function() draggingHit = false end)
    
    -- Tween Speed (0.1-1)
    tweenSliderBg.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.Touch or input.UserInputType == Enum.UserInputType.MouseButton1 then
            local pos = math.clamp((input.Position.X - tweenSliderBg.AbsolutePosition.X) / tweenSliderBg.AbsoluteSize.X, 0, 1)
            local value = 0.1 + (pos * 0.9)
            tweenSliderFill.Size = UDim2.new(pos, 0, 1, 0)
            tweenKnob.Position = UDim2.new(pos, -6, 0.5, -6)
            tweenLabel.Text = "🌀 Tween Speed: " .. string.format("%.1f", value) .. "s"
            Settings.TweenSpeed = value
            draggingTween = true
        end
    end)
    
